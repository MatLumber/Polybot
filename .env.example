# PolyBot Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Wallet Configuration
# ===========================================

# Your Polygon private key (0x prefix, 66 chars total)
# WARNING: Never share this!
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your wallet address (0x prefix)
POLYMARKET_ADDRESS=0xYOUR_ADDRESS_HERE

# Required for proxy / safe accounts (signature_type 1 or 2)
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS_HERE

# ===========================================
# SHADOW MODE (Dry Run)
# ===========================================

# dry_run=true means NO real orders are executed
# Only observes prices and generates signals
POLYBOT__BOT__DRY_RUN=true

# paper_trading.enabled=true keeps execution in the simulated engine
POLYBOT__PAPER_TRADING__ENABLED=true

# ===========================================
# OPTIONAL: Logging
# ===========================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info,polybot=debug

# ===========================================
# TRADING CONFIGURATION
# ===========================================

# LIVE CLOB credentials (required when DRY_RUN=false)
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_api_passphrase

# Signature type: 0=EOA, 1=proxy, 2=safe
POLYBOT__EXECUTION__SIGNATURE_TYPE=0

# Dashboard backend port
DASHBOARD_PORT=3000

# Minimum confidence for signals (0.6 = 60%)
POLYBOT__STRATEGY__MIN_CONFIDENCE=0.6

# Max per position in USDC
POLYBOT__RISK__MAX_POSITION_USDC=100

# Max daily loss in USDC
POLYBOT__RISK__MAX_DAILY_LOSS_USDC=50
